# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Anthropic API key, used by the default attack provider (Claude Haiku 4.5).
ANTHROPIC_API_KEY=

# Optional: needed only with ATTACK_PROVIDER=gemini (cross-model rewriting check,
# defaults to gemini-2.5-flash).
GEMINI_API_KEY=

# Optional: only needed if you switch ATTACK_PROVIDER to "openai" in src/config.py
OPENAI_API_KEY=
